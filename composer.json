{
    "name": "nih/middleware-dispatcher",
    "type": "library",
    "license": "MIT",
    "description": "Fiber-based PSR-15 middleware dispatcher with lazy PSR-11 middleware resolution.",
    "keywords": [
        "middleware",
        "dispatcher",
        "pipeline",
        "fiber",
        "psr-15"
    ],
    "support": {
        "issues": "https://github.com/nih-soft/middleware-dispatcher/issues?state=open",
        "source": "https://github.com/nih-soft/middleware-dispatcher"
    },
    "require": {
        "php": "8.4 - 8.5",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "NIH\\MiddlewareDispatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NIH\\MiddlewareDispatcher\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "scripts-descriptions": {
        "test": "Run all tests"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "psr/http-factory": "^1.1"
    }
}
